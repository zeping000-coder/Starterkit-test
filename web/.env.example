# ============================================
# 이 파일은 "샘플"입니다. 실제 값은 여기에 적지 마세요!
# 사용법: 이 파일을 복사해서 ".env" 라는 이름으로 만들고,
#        그 안에 진짜 키 값을 채워 넣으세요.
#   cp .env.example .env
# .env 는 .gitignore에 등록되어 있어 깃에 올라가지 않습니다.
# (참고: Prisma CLI가 dotenv로 직접 .env를 읽기 때문에,
#  Next.js 전용 규칙인 .env.local 대신 .env 하나로 통일했습니다)
# ============================================

# --- Supabase (DB + 인증) ---
# Supabase 프로젝트 생성 후 Settings > API 에서 확인 가능
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용 비밀 키 (절대 NEXT_PUBLIC_ 접두사 붙이지 말 것! 브라우저에 노출됨)
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma (DB 연결 문자열) ---
# Supabase Settings > Database > Connection string 에서 확인
DATABASE_URL=

# --- 한국투자증권(KIS) API (계좌 조회용, 모의투자로 먼저 발급) ---
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# 모의투자 서버 여부 (true = 모의투자, false = 실전투자)
KIS_IS_MOCK=true

# --- 해외 지표/데이터 API (선택, 무료 티어부터 시작) ---
FRED_API_KEY=
FINNHUB_API_KEY=
